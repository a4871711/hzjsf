        <result property="receivePhone" column="receivePhone" jdbcType="VARCHAR"/>
        <result property="receiveAddr" column="receiveAddr" jdbcType="VARCHAR"/>
        <result property="receiveAddrId" column="receiveAddrId" jdbcType="BIGINT"/>
        <result property="shopAddrId" column="shopAddrId" jdbcType="BIGINT"/>
        <result property="transactionNo" column="transactionNo" jdbcType="VARCHAR"/>
