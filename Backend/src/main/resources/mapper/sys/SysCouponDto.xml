    <sql id="selectSysCouponVo">
        select sysCouponId, couponStatus, validity, couponPrice, createdDate, limitPrice, couponType, storeAddrIds, couponTitle, limitUser, limitAll, sendCount, fitCardIds, goodsId, douyin_sku_id, couponNew from sys_coupon
    </sql>

    <select id="selectSysCouponList" parameterType="com.dlc.modules.sys.entity.SysCouponEntity" resultMap="SysCouponResult">
        <include refid="selectSysCouponVo"/>
        <where>  
            <if test="couponStatus != null "> and couponStatus = #{couponStatus}</if>
            <if test="validity != null "> and validity = #{validity}</if>
            <if test="couponPrice != null "> and couponPrice = #{couponPrice}</if>
            <if test="createdDate != null "> and createdDate = #{createdDate}</if>
            <if test="limitPrice != null "> and limitPrice = #{limitPrice}</if>
            <if test="couponType != null "> and couponType = #{couponType}</if>
            <if test="couponNew != null "> and couponNew = #{couponNew}</if>
            <if test="goodsId != null "> and goodsId = #{goodsId}</if>
            <if test="douyinSkuId != null and douyinSkuId != ''"> and douyin_sku_id = #{douyinSkuId}</if>
            <if test="couponTitle != null  and couponTitle != ''"> and couponTitle like concat('%', #{couponTitle}, '%')</if>
            <if test="limitUser != null "> and limitUser = #{limitUser}</if>
            <if test="limitAll != null "> and limitAll = #{limitAll}</if>
            <if test="sendCount != null "> and sendCount = #{sendCount}</if>
            <if test="fitCardIds != null  and fitCardIds != ''"> and find_in_set(#{fitCardIds}, fitCardIds)</if>
            <if test="startTime != null and ''!=startTime and endTime!=null and endTime!=''">
                AND createdDate between #{startTime} and #{endTime}
            </if>
            <if test="storeAddrIds != null and storeAddrIds != ''">
                AND (HaveCommonElements(storeAddrIds, #{storeAddrIds}) or storeAddrIds='' or storeAddrIds is null)
            </if>
        </where>
        ORDER BY sysCouponId DESC
        <if test="offset != null and limit != null">
            limit #{offset}, #{limit}
        </if>
    </select>
    
    <select id="selectSysCouponCount" parameterType="com.dlc.modules.sys.entity.SysCouponEntity" resultType="int">
