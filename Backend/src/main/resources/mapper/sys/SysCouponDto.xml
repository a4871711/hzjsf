    <delete id="deleteSysCouponById" parameterType="Long">
        delete from sys_coupon where sysCouponId = #{sysCouponId}
    </delete>

    <delete id="deleteSysCouponByIds" parameterType="String">
        delete from sys_coupon where sysCouponId in 
        <foreach item="sysCouponId" collection="array" open="(" separator="," close=")">
            #{sysCouponId}
        </foreach>
    </delete>
    
    <!--统计-->
    <select id="selectCouponStats" resultType="java.util.Map" parameterType="java.util.Map">
        SELECT         	
        	sum(if(c.couponType=1,1,0)) as douyin,
        	sum(if(c.couponType=2,1,0)) as meituan
        FROM coupon c
        <where>
        	c.couponStatus in (0,1,2)
            <if test="storeAddressId != null  and storeAddressId != ''"> and find_in_set(#{storeAddressId}, c.storeAddrIds)</if>    
            <if test="storeAddressIds != null and storeAddressIds != ''">
                AND HaveCommonElements(c.storeAddrIds, #{storeAddressIds})
            </if>        
            <if test="sdate!=null and sdate!='' and edate!=null and edate!=''">
                AND c.createdDate BETWEEN #{sdate} AND #{edate}
            </if>
        </where>
    </select>
