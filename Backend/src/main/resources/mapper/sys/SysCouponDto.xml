    <update id="updateSysCoupon" parameterType="com.dlc.modules.sys.entity.SysCouponEntity">
        update sys_coupon
        <trim prefix="SET" suffixOverrides=",">
            <if test="couponStatus != null">couponStatus = #{couponStatus},</if>
            <if test="validity != null">validity = #{validity},</if>
            <if test="couponPrice != null">couponPrice = #{couponPrice},</if>
