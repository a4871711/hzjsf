    <resultMap type="com.dlc.modules.sys.entity.SysCouponEntity" id="SysCouponResult">
        <result property="sysCouponId"    column="sysCouponId"    />
        <result property="couponStatus"    column="couponStatus"    />
        <result property="validity"    column="validity"    />
        <result property="couponPrice"    column="couponPrice"    />
        <result property="createdDate"    column="createdDate"    />
        <result property="limitPrice"    column="limitPrice"    />
