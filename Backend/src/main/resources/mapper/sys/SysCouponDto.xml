            </if>
            <if test="storeAddrIds != null and storeAddrIds != ''">
                AND (HaveCommonElements(storeAddrIds, #{storeAddrIds}) or storeAddrIds='' or storeAddrIds is null)
            </if>
        </where>
    </select>
    
    <select id="selectSysCouponById" parameterType="Long" resultMap="SysCouponResult">
        <include refid="selectSysCouponVo"/>
        where sysCouponId = #{sysCouponId}
    </select>
        
    <insert id="insertSysCoupon" parameterType="com.dlc.modules.sys.entity.SysCouponEntity" useGeneratedKeys="true" keyProperty="sysCouponId">
        insert into sys_coupon
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="couponStatus != null">couponStatus,</if>
            <if test="validity != null">validity,</if>
            <if test="couponPrice != null">couponPrice,</if>
            <if test="createdDate != null">createdDate,</if>
            <if test="limitPrice != null">limitPrice,</if>
