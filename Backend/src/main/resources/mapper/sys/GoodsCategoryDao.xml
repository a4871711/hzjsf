<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dlc.modules.sys.dao.SysGoodsCategoryDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.dlc.modules.sys.entity.SysGoodsCategoryEntity" id="goodsCategoryMap">
        <result property="goodsCategoryId" column="goodsCategoryId"/>
        <result property="categoryImg" column="categoryImg"/>
		<result property="categoryName" column="categoryName"/>
		<result property="createdDate" column="createdDate"/>
    </resultMap>

	<select id="queryObject" resultType="com.dlc.modules.sys.entity.SysGoodsCategoryEntity">
		select * from goods_category where goodsCategoryId = #{value}
	</select>

	<select id="queryList" resultType="com.dlc.modules.sys.entity.SysGoodsCategoryEntity">
		select * from goods_category
		<where>
			<if test="categoryName != null and categoryName != ''">
				AND categoryName LIKE concat('%',#{categoryName},'%')
			</if>
		</where>
        <choose>
            <when test="sidx != null and sidx.trim() != ''">
                order by ${sidx} ${order}
            </when>
			<otherwise>
                order by goodsCategoryId desc
			</otherwise>
        </choose>
		<if test="offset != null and limit != null">
			limit #{offset}, #{limit}
		</if>
	</select>
	
 	<select id="queryTotal" resultType="int">
		select count(*) from goods_category
		<where>
			<if test="categoryName != null and categoryName != ''">
				AND categoryName LIKE concat('%',#{categoryName},'%')
			</if>
		</where>
	</select>
	 
	<insert id="save" parameterType="com.dlc.modules.sys.entity.SysGoodsCategoryEntity" useGeneratedKeys="true" keyProperty="goodsCategoryId">
		insert into goods_category
		(
			`categoryImg`,
			`categoryName`,
			`createdDate`
		)
		values
		(
			#{categoryImg},
			#{categoryName},
			#{createdDate}
		)
	</insert>
	 
	<update id="update" parameterType="com.dlc.modules.sys.entity.SysGoodsCategoryEntity">
		update goods_category
		<set>
			<if test="categoryImg != null">`categoryImg` = #{categoryImg},</if>
			<if test="categoryName != null">`categoryName` = #{categoryName},</if>
			<if test="createdDate != null">`createdDate` = #{createdDate}</if>
		</set>
		where goodsCategoryId = #{goodsCategoryId}
	</update>

	<delete id="delete">
		delete from goods_category where goodsCategoryId = #{value}
	</delete>

	<delete id="deleteBatch">
		delete from goods_category where id in
		<foreach item="id" collection="array" open="(" separator="," close=")">
			#{id}
		</foreach>
	</delete>

	<!--查询一级分类的数据绑定在二级分类的下拉框中显示-->
	<select id="queryGoodsCategoryList" resultType="com.dlc.modules.sys.entity.SysGoodsCategoryEntity">
		select goodsCategoryId,categoryName from goods_category
	</select>

</mapper>