<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dlc.modules.sys.dao.PtCoachFeeRuleDao">

    <select id="queryObject" resultType="com.dlc.modules.sys.entity.PtCoachFeeRuleEntity">
        select * from pt_coach_fee_rule where id = #{value}
    </select>

    <select id="queryList" resultType="com.dlc.modules.sys.entity.PtCoachFeeRuleEntity">
        select f.*, (select coach_name from pt_coach where id = f.coach_id) as coachName
        from pt_coach_fee_rule f
        <where>
            <if test="coachId != null and coachId != ''">AND f.coach_id = #{coachId}</if>
            <if test="ruleType != null and ruleType != ''">AND f.rule_type = #{ruleType}</if>
            <if test="status != null and status != ''">AND f.status = #{status}</if>
            <if test="storeId != null and storeId != ''">AND f.store_id = #{storeId}</if>
            <if test="productId != null and productId != ''">AND f.product_id = #{productId}</if>
        </where>
        <choose>
            <when test="sidx != null and sidx.trim() != ''">
                order by ${sidx} ${order}
            </when>
            <otherwise>
                order by f.id desc
            </otherwise>
        </choose>
        <if test="offset != null and limit != null">
            limit #{offset}, #{limit}
        </if>
    </select>

    <select id="queryTotal" resultType="int">
        select count(*) from pt_coach_fee_rule f
        <where>
            <if test="coachId != null and coachId != ''">AND f.coach_id = #{coachId}</if>
            <if test="ruleType != null and ruleType != ''">AND f.rule_type = #{ruleType}</if>
            <if test="status != null and status != ''">AND f.status = #{status}</if>
            <if test="storeId != null and storeId != ''">AND f.store_id = #{storeId}</if>
            <if test="productId != null and productId != ''">AND f.product_id = #{productId}</if>
        </where>
    </select>

    <insert id="save" parameterType="com.dlc.modules.sys.entity.PtCoachFeeRuleEntity" useGeneratedKeys="true" keyProperty="id">
        insert into pt_coach_fee_rule
        (`coach_id`, `product_id`, `store_id`, `rule_name`, `rule_type`, `lesson_fee`,
         `commission_rate`, `effective_time`, `status`,
         `created_by`, `created_at`, `updated_by`, `updated_at`)
        values
        (#{coachId}, #{productId}, #{storeId}, #{ruleName}, #{ruleType}, #{lessonFee},
         #{commissionRate}, #{effectiveTime}, #{status},
         #{createdBy}, #{createdAt}, #{updatedBy}, #{updatedAt})
    </insert>

    <update id="update" parameterType="com.dlc.modules.sys.entity.PtCoachFeeRuleEntity">
        update pt_coach_fee_rule
        <set>
            <if test="ruleName != null">`rule_name` = #{ruleName},</if>
            <if test="ruleType != null">`rule_type` = #{ruleType},</if>
            <if test="lessonFee != null">`lesson_fee` = #{lessonFee},</if>
            <if test="commissionRate != null">`commission_rate` = #{commissionRate},</if>
            <if test="effectiveTime != null">`effective_time` = #{effectiveTime},</if>
            <if test="status != null">`status` = #{status},</if>
            <if test="storeId != null">`store_id` = #{storeId},</if>
            <if test="productId != null">`product_id` = #{productId},</if>
            <if test="updatedBy != null">`updated_by` = #{updatedBy},</if>
            <if test="updatedAt != null">`updated_at` = #{updatedAt},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteBatch">
        delete from pt_coach_fee_rule where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="countByUk" resultType="int">
        select count(*) from pt_coach_fee_rule
        where coach_id = #{coachId} and product_id = #{productId}
          and store_id = #{storeId} and rule_type = #{ruleType}
        <if test="excludeId != null">AND id &lt;&gt; #{excludeId}</if>
    </select>

    <select id="queryEnabledByCoach" resultType="com.dlc.modules.sys.entity.PtCoachFeeRuleEntity">
        select * from pt_coach_fee_rule
        where coach_id = #{coachId} and status = 1
        <if test="ruleType != null">AND rule_type = #{ruleType}</if>
    </select>

</mapper>
