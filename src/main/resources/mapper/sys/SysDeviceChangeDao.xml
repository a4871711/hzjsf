    <sql id="Base_Column_List">
        deviceId,deviceNo,deviceName,proxyId,deviceImgUrl,storeId,proxyName,phone,devicePrice,imei,addressDetail,addressId,status,inventory,onLineTime,createTime,newStoreAddressId,changeDate,sysUserId
    </sql>
    <select id="queryList" resultType="com.dlc.modules.sys.entity.SysDeviceChangeEntity" parameterType="map">
        SELECT
          d.*, ss.username, s.storeName, sa.storeName as newStoreName, u.nickname,u.phone as userPhone,u.headImgUrl,u.wtState,u.auditStatus,
          (select ct.ctName from card_type ct where ct.cardType=d.type limit 1) as ctName,
          (select group_concat(storeName) from store_address where find_in_set(storeAddrId, d.storeAddrIds)) as supportStoreName
        FROM device_change d 
        inner join store_address s on s.storeAddrId= d.storeAddressId
        inner join store_address sa on sa.storeAddrId= d.newStoreAddressId
        INNER JOIN sys_user ss ON ss.user_id = d.sysUserId
        INNER JOIN user_info u ON u.userId=d.proxyId
        where 1=1
        <if test="storeId != null and storeId != ''">
            AND d.storeId=#{storeId}
        </if>
            <if test="storeIds != null and storeIds != ''">
                AND d.storeId in (${storeIds})
            </if>
            <if test="storeAddressId != null and storeAddressId != ''">
                AND d.storeAddressId = #{storeAddressId}
            </if>
            <if test="newStoreAddressId != null and newStoreAddressId != ''">
                AND d.newStoreAddressId = #{newStoreAddressId}
            </if>            
        <if test="deviceNo != null and deviceNo != ''">
            AND d.deviceNo LIKE concat('%',#{deviceNo},'%')
        </if>
        <if test="storeName != null and storeName != ''">
            AND s.storeName LIKE concat('%',#{storeName},'%')
        </if>
        <if test="newStoreName != null and newStoreName != ''">
            AND sa.storeName LIKE concat('%',#{newStoreName},'%')
        </if>
        <if test="username != null and username != ''">
            AND ss.username LIKE concat('%',#{username},'%')
        </if>
        <if test="nickname != null and nickname != ''">
            AND u.nickname LIKE concat('%',#{nickname},'%')
        </if>
        <if test="phone != null and phone != ''">
            AND u.phone LIKE concat('%',#{phone},'%')
        </if>
        <if test="status != null and status != ''">
            AND d.status = #{status}
        </if>          
        <if test="startTime != null and !''.equals(startTime)">
            AND d.changeDate <![CDATA[>=]]> #{startTime}
        </if>
        <if test="endTime != null and !''.equals(endTime)">
            AND d.changeDate <![CDATA[<=]]> #{endTime}
        </if>
        order BY d.changeDate desc
        <if test="offset != null and limit != null">
            limit #{offset}, #{limit}
        </if>
    </select>
