<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dlc.modules.sys.dao.SysStoreDeviceDao">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.dlc.modules.sys.entity.SysStoreDeviceEntity" id="storeDeviceMap">
        <result property="sdId" column="sdId"/>
        <result property="storeId" column="storeId"/>
        <result property="deviceName" column="deviceName"/>
        <result property="deviceNo" column="deviceNo"/>
        <result property="createTime" column="createTime"/>
    </resultMap>
    <sql id="base_col">
      storeId,deviceName,deviceNo,createTime
    </sql>
    <select id="queryList" resultType="com.dlc.modules.sys.entity.SysStoreDeviceEntity" parameterType="map">
        select sd.*,s.storeName from store_device sd
        inner JOIN store s on sd.storeId=s.storeId
        <where>
            <if test="storeId != null and storeId != ''">
                AND sd.storeId = #{storeId}
            </if>
            <if test="storeIds != null and storeIds != ''">
                AND sd.storeId in (${storeIds})
            </if>
        </where>
        <choose>
            <when test="sidx != null and sidx.trim() != ''">
                order by ${sidx} ${order}
            </when>
            <otherwise>
                order by createTime desc
            </otherwise>
        </choose>
        <if test="offset != null and limit != null">
            limit #{offset}, #{limit}
        </if>
    </select>
    <select id="queryTotal" resultType="integer" parameterType="map">
        select count(1) from store_device sd inner JOIN store s on sd.storeId=s.storeId
        <where>
            <if test="storeId != null and storeId != ''">
                AND sd.storeId = #{storeId}
            </if>
            <if test="storeIds != null and storeIds != ''">
                AND sd.storeId in (${storeIds})
            </if>
        </where>
    </select>
    <select id="queryObject" parameterType="long" resultType="com.dlc.modules.sys.entity.SysStoreDeviceEntity">
      select * from store_device WHERE sdId=#{id}
    </select>
    <insert id="save" parameterType="com.dlc.modules.sys.entity.SysStoreDeviceEntity">
        insert into store_device(
        <include refid="base_col"/>
        ) values (
        #{storeId},
        #{deviceName},
        trim(#{deviceNo}),
        #{createTime}
        );
    </insert>
    <update id="update" parameterType="com.dlc.modules.sys.entity.SysStoreDeviceEntity">
        update store_device
        SET
        storeId=#{storeId},
        deviceName=#{deviceName},
        deviceNo=trim(#{deviceNo}),
        createTime=#{createTime}
        where sdId=#{sdId};
    </update>
    <delete id="deleteBatch">
        DELETE FROM store_device
        WHERE sdId
        IN
        <foreach collection="array" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </delete>
    <!--查已存在此设备-->
    <select id="queryExistSameDevice" resultType="java.lang.Integer" parameterType="java.lang.String">
        select count(*) from store_device WHERE deviceNo=trim(#{deviceNo})
    </select>
    <!---->
    <select id="querySameDevice" resultType="java.lang.Integer" parameterType="com.dlc.modules.sys.entity.SysStoreDeviceEntity">
        select COUNT(*) from store_device WHERE deviceNo=trim(#{deviceNo}) AND sdId <![CDATA[<>]]> #{sdId}
    </select>
</mapper>