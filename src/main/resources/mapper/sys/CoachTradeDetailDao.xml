<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dlc.modules.sys.dao.SysCoachTradeDetailDao">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.dlc.modules.sys.entity.SysCoachTradeDetailEntity" id="coachTradeDetailMap">
        <result property="id" column="id"/>
        <result property="coachId" column="coachId"/>
        <result property="tradeType" column="tradeType"/>
        <result property="money" column="money"/>
        <result property="origMoney" column="origMoney"/>
        <result property="percent" column="percent"/>
        <result property="aliAccount" column="AliAccount"/>
        <result property="wxCount" column="wxCount"/>
        <result property="transactionNumber" column="transactionNumber"/>
        <result property="reason" column="reason"/>
        <result property="orderNo" column="orderNo"/>
        <result property="status" column="status"/>
        <result property="checkedTime" column="checkedTime"/>
        <result property="transactionTime" column="transactionTime"/>
        <result property="createTime" column="createTime"/>
    </resultMap>
    <sql id="base_col">
        coachId,
        tradeType,
        money,
        AliAccount,
        wxCount,
         transactionNumber,
         reason,
         orderNo,
         status,
          checkedTime,
          transactionTime,
          createTime
                            </sql>
    <select id="queryList" resultType="com.dlc.modules.sys.entity.SysCoachTradeDetailEntity" parameterType="map">
        select ctd.*,c.coachName,c.phone from coach_trade_detail ctd
        INNER JOIN coach c on ctd.coachId=c.coachId
        <where>
            <if test="phone!=null and phone!=''">
                AND  c.phone like concat('%',trim(#{phone}),'%')
            </if>
            <if test="coachName!=null and coachName!=''">
                AND  c.coachName like concat('%',trim(#{coachName}),'%')
            </if>
            <if test="status!=null and status!=''">
                AND  ctd.status =#{status}
            </if>
            <if test="sdate!=null and sdate!='' and edate!=null and edate!=''">
                AND ctd.createTime BETWEEN #{sdate} AND #{edate}
            </if>
        </where>
        <choose>
            <when test="sidx != null and sidx.trim() != ''">
                order by ${sidx} ${order}
            </when>
            <otherwise>
                order by createTime desc
            </otherwise>
        </choose>
        <if test="offset != null and limit != null">
            limit #{offset}, #{limit}
        </if>
    </select>
    <select id="queryTotal" resultType="integer" parameterType="map">
        select count(1) from coach_trade_detail ctd
        INNER JOIN coach c on ctd.coachId=c.coachId
        <where>
            <if test="phone!=null and phone!=''">
                AND  c.phone like concat('%',trim(#{phone}),'%')
            </if>
            <if test="coachName!=null and coachName!=''">
                AND  c.coachName like concat('%',trim(#{coachName}),'%')
            </if>
            <if test="status!=null and status!=''">
                AND  ctd.status =#{status}
            </if>
            <if test="sdate!=null and sdate!='' and edate!=null and edate!=''">
                AND ctd.createTime BETWEEN #{sdate} AND #{edate}
            </if>
        </where>
    </select>
    <select id="queryObject" parameterType="long" resultType="com.dlc.modules.sys.entity.SysCoachTradeDetailEntity">
        select * from coach_trade_detail WHERE id=#{id}
    </select>
    <insert id="save" parameterType="com.dlc.modules.sys.entity.SysCoachTradeDetailEntity">
        insert into coach_trade_detail(
        <include refid="base_col"/>
        ) values (
        #{coachId},
        #{tradeType},
        #{money},
        #{AliAccount},
        #{wxCount},
        #{transactionNumber},
        #{reason},
        #{orderNo},
        #{status},
        #{checkedTime},
        #{transactionTime},
        #{createTime});
    </insert>
    <update id="update" parameterType="com.dlc.modules.sys.entity.SysCoachTradeDetailEntity">
        update coach_trade_detail
        SET
          coachId=#{coachId},
           tradeType=#{tradeType},
           money=#{money},
           AliAccount=#{aliAccount},
          wxCount=#{wxCount},
           transactionNumber=#{transactionNumber},
            reason=#{reason},
              orderNo=#{orderNo},
            status=#{status},
             checkedTime=#{checkedTime},
             transactionTime=#{transactionTime},
             createTime=#{createTime}
             where id=#{id};
    </update>
    <delete id="deleteBatch">
        DELETE FROM coach_trade_detail
        WHERE id
        IN
        <foreach collection="array" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </delete>
</mapper>