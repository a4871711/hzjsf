        #{atId,jdbcType=BIGINT},
      </if>
      <if test="atName != null" >
        #{atName,jdbcType=VARCHAR},
      </if>
      <if test="createdDate != null" >
        #{createdDate,jdbcType=TIMESTAMP},
      </if>
    </trim>
  </insert>
  <update id="updateByPrimaryKeySelective" parameterType="com.dlc.modules.api.entity.ActivityType" >
    update activity_type
    <set >
      <if test="atName != null" >
        atName = #{atName,jdbcType=VARCHAR},
      </if>
      <if test="createdDate != null" >
        createdDate = #{createdDate,jdbcType=TIMESTAMP},
      </if>
    </set>
    where atId = #{atId,jdbcType=BIGINT}
  </update>
  <update id="updateByPrimaryKey" parameterType="com.dlc.modules.api.entity.ActivityType" >
    update activity_type
    set atName = #{atName,jdbcType=VARCHAR},
      createdDate = #{createdDate,jdbcType=TIMESTAMP}
    where atId = #{atId,jdbcType=BIGINT}
  </update>
    <!--后台分类列表-->
    <select id="queryActivTypeList" resultType="com.dlc.modules.api.entity.ActivityType" parameterType="java.util.Map">
        select
          *
        from activity_type
        <where>
            <if test="atName != null and atName != ''">
                atName LIKE concat('%',#{atName},'%')
            </if>
        </where>
        ORDER BY createdDate DESC
        <if test="offset != null and limit != null">
            limit #{offset}, #{limit}
        </if>
    </select>
    <!--后台分类列表总数-->
    <select id="queryActivTypeTotal" resultType="java.lang.Integer" parameterType="java.util.Map">
        select
          COUNT(*)
        from activity_type
        <where>
            <if test="atName != null and atName != ''">
                atName LIKE concat('%',#{atName},'%')
            </if>
        </where>
    </select>
  <!--分类列表-->
  <select id="queryActivityTypeList" resultType="java.util.Map" parameterType="java.util.Map">
      select
        atId, atName
      from activity_type
      ORDER BY createdDate DESC
      <if test="offset != null and limit != null">
          limit #{offset}, #{limit}
      </if>
  </select>
    <!--总数-->
    <select id="queryActivityTypeTotal" resultType="java.lang.Integer" parameterType="java.util.Map">
