     ORDER BY createdDate DESC
  </select>
  <delete id="deleteByPrimaryKey" parameterType="java.lang.Long" >
    delete from activity_type
    where atId = #{atId,jdbcType=BIGINT}
  </delete>
  <insert id="insert" parameterType="com.dlc.modules.api.entity.ActivityType" >
    insert into activity_type (atId, atName, createdDate
      )
    values (#{atId,jdbcType=BIGINT}, #{atName,jdbcType=VARCHAR}, #{createdDate,jdbcType=TIMESTAMP}
      )
  </insert>
  <insert id="insertSelective" parameterType="com.dlc.modules.api.entity.ActivityType" >
    insert into activity_type
    <trim prefix="(" suffix=")" suffixOverrides="," >
      <if test="atId != null" >
        atId,
      </if>
      <if test="atName != null" >
        atName,
      </if>
      <if test="createdDate != null" >
        createdDate,
      </if>
